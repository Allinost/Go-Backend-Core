{
  "dashboard": {
    "title": "Go Backend Core - Overview",
    "tags": ["go", "backend", "core"],
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "title": "HTTP Requests Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{path}}"
          }
        ]
      },
      {
        "title": "HTTP Request Duration (p95)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "title": "Active Goroutines",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "go_goroutines",
            "legendFormat": "goroutines"
          }
        ]
      },
      {
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "go_memstats_alloc_bytes",
            "legendFormat": "alloc"
          },
          {
            "expr": "go_memstats_sys_bytes",
            "legendFormat": "sys"
          }
        ]
      },
      {
        "title": "GC Duration",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "go_gc_duration_seconds",
            "legendFormat": "gc_duration"
          }
        ]
      },
      {
        "title": "Database Connections",
        "type": "graph",
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sql_db_open_connections",
            "legendFormat": "open"
          },
          {
            "expr": "sql_db_idle_connections",
            "legendFormat": "idle"
          }
        ]
      }
    ]
  }
}