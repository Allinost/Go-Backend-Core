# Go-Backend-Core 环境变量模板
# 复制为 .env 并填入实际值，.env 已加入 .gitignore 不会被提交
#
# 优先级: Docker Secret > .env > config.yaml > 默认值
# 命名规则: APP_ + 配置路径(大写 + 下划线)，如 server.port → APP_SERVER_PORT

# 服务器
APP_SERVER_MODE=debug

# 数据库 MySQL（主数据库）
APP_DATABASE_MYSQL_MAIN_HOST=localhost
APP_DATABASE_MYSQL_MAIN_PORT=3306
APP_DATABASE_MYSQL_MAIN_USER=root
APP_DATABASE_MYSQL_MAIN_PASSWORD=your_password_here
APP_DATABASE_MYSQL_MAIN_DBNAME=go_backend_core

# 数据库 PostgreSQL（NAS 辅助）
APP_DATABASE_POSTGRES_NAS_HOST=localhost
APP_DATABASE_POSTGRES_NAS_PORT=5432
APP_DATABASE_POSTGRES_NAS_USER=postgres
APP_DATABASE_POSTGRES_NAS_PASSWORD=your_password_here
APP_DATABASE_POSTGRES_NAS_DBNAME=go_backend_core

# Redis
APP_REDIS_MAIN_ADDR=localhost:6379
APP_REDIS_MAIN_PASSWORD=
APP_REDIS_MAIN_DB=0

# JWT
APP_AUTH_JWT_SECRET=change-me-in-production
APP_AUTH_JWT_EXPIRE=24h
