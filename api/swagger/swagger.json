{
    "swagger": "2.0",
    "info": {
        "description": "模块化 Go 后端服务 API 文档",
        "title": "Go Backend Core API",
        "termsOfService": "https://github.com/Allinost/go-backend-core",
        "contact": {
            "name": "Allinost",
            "url": "https://github.com/Allinost/go-backend-core"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "0.1.0"
    },
    "host": "localhost:29090",
    "basePath": "/api/v1",
    "paths": {
        "/auth/login": {
            "post": {
                "description": "使用用户名/邮箱和密码登录，返回 JWT token 对",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth-认证"
                ],
                "summary": "用户密码登录",
                "parameters": [
                    {
                        "description": "登录请求",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_services_auth.LoginRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_services_auth.TokenPair"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "将当前 JWT token 加入黑名单，立即失效",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth-认证"
                ],
                "summary": "用户注销",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/auth/me": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "返回当前登录用户的详细信息",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth-用户"
                ],
                "summary": "获取当前用户信息",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/auth/refresh": {
            "post": {
                "description": "使用 refresh_token 获取新的 access_token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth-认证"
                ],
                "summary": "刷新访问令牌",
                "parameters": [
                    {
                        "description": "刷新令牌",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "refresh_token": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_services_auth.TokenPair"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/auth/register": {
            "post": {
                "description": "使用用户名/邮箱和密码注册新用户",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth-认证"
                ],
                "summary": "用户注册",
                "parameters": [
                    {
                        "description": "注册请求",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_services_auth.RegisterRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_services_auth.TokenPair"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/auth/{provider}/callback": {
            "post": {
                "description": "第三方登录授权回调处理，自动注册或登录",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth-社交登录"
                ],
                "summary": "OAuth 登录回调",
                "parameters": [
                    {
                        "type": "string",
                        "description": "平台名称",
                        "name": "provider",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "授权码",
                        "name": "code",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_services_auth.TokenPair"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/auth/{provider}/url": {
            "get": {
                "description": "获取指定第三方登录平台的授权跳转 URL",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth-社交登录"
                ],
                "summary": "获取 OAuth 授权 URL",
                "parameters": [
                    {
                        "type": "string",
                        "description": "平台名称: wechat/feishu/qq/apple/huawei/honor",
                        "name": "provider",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "auth_url": {
                                                    "type": "string"
                                                },
                                                "provider": {
                                                    "type": "string"
                                                },
                                                "state": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/s0/echo": {
            "get": {
                "description": "返回请求的详细信息，包括方法、路径、查询参数、请求头和客户端 IP",
                "tags": [
                    "s0-调试"
                ],
                "summary": "请求回显（调试用）",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "client_ip": {
                                                    "type": "string"
                                                },
                                                "headers": {
                                                    "type": "object"
                                                },
                                                "method": {
                                                    "type": "string"
                                                },
                                                "path": {
                                                    "type": "string"
                                                },
                                                "query": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/s0/health": {
            "get": {
                "description": "返回所有依赖服务的健康检查结果",
                "tags": [
                    "s0-调试"
                ],
                "summary": "全服务健康状态",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "checks": {
                                                    "type": "object"
                                                },
                                                "status": {
                                                    "type": "string"
                                                },
                                                "uptime": {
                                                    "type": "string"
                                                },
                                                "version": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/s0/info": {
            "get": {
                "description": "返回服务名称、版本、运行时长、Go 运行时信息等",
                "tags": [
                    "s0-调试"
                ],
                "summary": "服务信息",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "config_watch": {
                                                    "type": "boolean"
                                                },
                                                "go_arch": {
                                                    "type": "string"
                                                },
                                                "go_os": {
                                                    "type": "string"
                                                },
                                                "go_version": {
                                                    "type": "string"
                                                },
                                                "goroutines": {
                                                    "type": "integer"
                                                },
                                                "mode": {
                                                    "type": "string"
                                                },
                                                "modules": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string"
                                                    }
                                                },
                                                "name": {
                                                    "type": "string"
                                                },
                                                "start_time": {
                                                    "type": "string"
                                                },
                                                "uptime": {
                                                    "type": "string"
                                                },
                                                "version": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/s0/metrics": {
            "get": {
                "description": "返回 Prometheus 格式的监控指标",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "s0-调试"
                ],
                "summary": "Prometheus 指标暴露",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/s0/modules": {
            "get": {
                "description": "返回所有已注册的业务模块名称",
                "tags": [
                    "s0-调试"
                ],
                "summary": "已注册模块列表",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "count": {
                                                    "type": "integer"
                                                },
                                                "modules": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/s0/ping": {
            "get": {
                "description": "返回 pong 表示服务运行正常",
                "tags": [
                    "s0-调试"
                ],
                "summary": "存活检查",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_Allinost_go-backend-core_internal_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "github_com_Allinost_go-backend-core_internal_pkg_response.Response": {
            "type": "object",
            "properties": {
                "code": {
                    "description": "业务错误码（0 表示成功）",
                    "type": "integer"
                },
                "data": {
                    "description": "响应数据"
                },
                "detail": {
                    "description": "错误详情（仅开发环境可见）",
                    "type": "string"
                },
                "message": {
                    "description": "提示信息",
                    "type": "string"
                },
                "trace_id": {
                    "description": "请求追踪 ID",
                    "type": "string"
                }
            }
        },
        "github_com_Allinost_go-backend-core_internal_services_auth.LoginRequest": {
            "type": "object",
            "required": [
                "password",
                "username"
            ],
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "github_com_Allinost_go-backend-core_internal_services_auth.RegisterRequest": {
            "type": "object",
            "required": [
                "password",
                "username"
            ],
            "properties": {
                "nickname": {
                    "type": "string"
                },
                "password": {
                    "type": "string",
                    "maxLength": 128,
                    "minLength": 6
                },
                "username": {
                    "type": "string",
                    "maxLength": 32,
                    "minLength": 3
                }
            }
        },
        "github_com_Allinost_go-backend-core_internal_services_auth.TokenPair": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "expires_in": {
                    "type": "integer"
                },
                "refresh_token": {
                    "type": "string"
                },
                "user_id": {
                    "type": "integer"
                },
                "username": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "JWT Bearer token, 格式: \"Bearer {token}\"",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}